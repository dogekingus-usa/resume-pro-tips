  const cats = {resume:{label:"Resume Tips",cls:"cat-resume",emoji:"ðŸœž"},linkedin:{label:"LinkedIn",cls:"cat-linkedin",emoji:"ðŸ™¼"},interview:{label:"Interviews",cls:"cat-interview",emoji:"ðŸŽ¤"},career:{label:"Career",cls:"cat-career",emoji:"ðŸš€"},ats:{label:"ATS/AI",cls:"cat-ats",emoji:"ðŸ¤�œ"},general:{label:"General",cls:"cat-general",emoji:"ðŸœ"}};
  let currentCat='all';

  function renderArticles(filtered){
    const grid=document.getElementById('articlesGrid');
    grid.innerHTML='';
    filtered.forEach((a,i)=>{
      const c=cats[a.category]||cats.general;
      const card=document.createElement('a');
      card.href=`/articles/${a.slug}.html`;
      card.className='article-card';
      card.dataset.category=a.category;
      card.style.transitionDelay=`${(i%9)*50}ms`;
      card.innerHTML=`<span class="cat-badge ${c.cls}">${c.emoji} ${c.label}</span><div class="meta"><span>${a.date}</span><span class="dot"></span><span>${a.readTime} read</span></div><h3>${a.title}</h3><p class="excerpt">${a.excerpt}</p><div class="tags">${a.tags.slice(0,3).map(t=>`<span class="tag">${t}</span>`).join('')}</div>`;
      grid.appendChild(card);
    });
    requestAnimationFrame(()=>{document.querySelectorAll('.article-card').forEach((el,i)=>{setTimeout(()=>el.classList.add('visible'),i*50)})});
    document.getElementById('articleCount').textContent=`${filtered.length} article${filtered.length!==1?'s':''}`;
  }

  function filterCat(cat,btn){
    currentCat=cat;
    document.querySelectorAll('.cat-chip').forEach(c=>c.classList.remove('active'));
    if(btn)btn.classList.add('active');
    renderArticles(cat==='all'?articles:articles.filter(a=>a.category===cat));
  }

  // Article grid filtering
  function filterArticlesGrid(category) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    document.querySelector(`.filter-btn[data-filter="${category}"]`).classList.add('active');
    document.querySelectorAll('.article-card').forEach(card => {
      card.style.display = (category === 'all' || card.dataset.category === category) ? '' : 'none';
    });
  }

  // Article grid search
  function searchArticlesGrid(query) {
    const q = query.toLowerCase().trim();
    document.querySelectorAll('.article-card').forEach(card => {
      const title = card.querySelector('h3')?.textContent?.toLowerCase() || '';
      const excerpt = card.querySelector('.excerpt')?.textContent?.toLowerCase() || '';
      card.style.display = (!q || title.includes(q) || excerpt.includes(q)) ? '' : 'none';
    });
  }

  function toggleNav(){document.getElementById('navLinks').classList.toggle('mobile-open')}

  function handleNewsletter(e) {
  e.preventDefault();
  const name = document.getElementById('newsletterName').value.trim();
  const email = document.getElementById('newsletterEmail').value.trim();
  const btn = document.getElementById('newsletterSubmitBtn');
  const form = document.getElementById('newsletterForm');
  const success = document.getElementById('newsletterSuccess');
  
  // Clear previous error
  const existingError = document.getElementById('newsletterError');
  if (existingError) existingError.remove();
  
  // Validate name
  if (!name || name.length < 2) {
    showNewsletterError('Please enter your first name');
    return false;
  }
  
  // Validate email with proper regex
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!email || !emailRegex.test(email)) {
    showNewsletterError('Please enter a valid email address');
    return false;
  }
  
  // Store subscriber locally (as backup)
  try {
    const subscribers = JSON.parse(localStorage.getItem('subscribers') || '[]');
    subscribers.push({ name, email, date: new Date().toISOString() });
    localStorage.setItem('subscribers', JSON.stringify(subscribers));
    localStorage.setItem('last_subscriber_email', email);
    localStorage.setItem('last_subscriber_name', name);
  } catch(e) {}
  
  // Send to backend (ConvertKit-compatible)
  btn.textContent = 'Subscribing...';
  btn.disabled = true;
  
  const formData = new FormData();
  formData.append('name', name);
  formData.append('email', email);
  formData.append('source', window.location.hostname);
  formData.append('tags', 'newsletter');
  
  // Use fetch to submit (ConvertKit API endpoint - to be configured)
  const ckUrl = (window.SITE_CONFIG && window.SITE_CONFIG.CONVERTKIT_API_URL) || 'https://api.convertkit.com/v3/forms/YOUR_FORM_ID/subscribe';
  fetch(ckUrl, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      api_key: (window.SITE_CONFIG && window.SITE_CONFIG.CONVERTKIT_API_KEY) || '***',
      email: email,
      first_name: name,
      tags: ['newsletter', window.location.hostname]
    })
  }).catch(function(err) {
    // Silently fall back to localStorage - submission will work offline
    console.log('Newsletter submission saved locally');
  }).finally(function() {
    // Show success state regardless
    btn.textContent = '\u2713 Subscribed!';
    btn.style.background = 'linear-gradient(135deg, #059669, #10b981)';
    setTimeout(function() {
      form.style.display = 'none';
      success.style.display = 'block';
    }, 800);
    
    // Track conversion
    if (typeof gtag !== 'undefined') {
      gtag('event', 'newsletter_signup', { event_category: 'conversion', event_label: email });
    }
  });
  
  // Track page view
  if (typeof localStorage !== 'undefined') {
    const visits = parseInt(localStorage.getItem('page_views') || '0') + 1;
    localStorage.setItem('page_views', visits.toString());
    localStorage.setItem('last_visit', new Date().toISOString());
  }
  
  return false;
}

function showNewsletterError(message) {
  const existing = document.getElementById('newsletterError');
  if (existing) existing.remove();
  
  const error = document.createElement('div');
  error.id = 'newsletterError';
  error.textContent = message;
  error.style.cssText = 'color:#ef4444;font-size:0.813rem;margin-top:0.5rem;text-align:center;animation:fadeInUp 0.3s ease';
  
  const form = document.getElementById('newsletterForm');
  form.parentNode.insertBefore(error, form.nextSibling);
  
  // Auto-remove after 4 seconds
  setTimeout(function() {
    if (error.parentNode) error.remove();
  }, 4000);
}

  document.addEventListener('keydown',(e)=>{if(e.key==='Escape'){document.getElementById('navLinks').classList.remove('mobile-open')}});

  const observer=new IntersectionObserver((entries)=>{entries.forEach(entry=>{if(entry.isIntersecting)entry.target.classList.add('visible')})},{threshold:0.1});

  document.addEventListener('DOMContentLoaded',()=>{
    renderArticles(articles);
    document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));
  });
  </script>

<!-- Lazy loading & performance enhancements -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const lazyImages = document.querySelectorAll('img[loading="lazy"]');
  if ('loading' in HTMLImageElement.prototype) {
    lazyImages.forEach(img => { img.loading = 'lazy'; });
  } else {
    const imageObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const img = entry.target;
          if (img.dataset.src) {
            img.src = img.dataset.src;
            img.removeAttribute('data-src');
          }
          imageObserver.unobserve(img);
        }
      });
    });
    lazyImages.forEach(img => imageObserver.observe(img));
  }
  
  document.querySelectorAll('footer p:first-child').forEach(p => {
    p.textContent = p.textContent.replace('2026', new Date().getFullYear().toString());
  });
  
  if (typeof localStorage !== 'undefined') {
    const startTime = Date.now();
    window.addEventListener('beforeunload', function() {
      const duration = Math.round((Date.now() - startTime) / 1000);
      const sessions = JSON.parse(localStorage.getItem('session_durations') || '[]');
      sessions.push({ page: window.location.pathname, duration, timestamp: new Date().toISOString() });
      localStorage.setItem('session_durations', JSON.stringify(sessions.slice(-50)));
    });
  }
});
</script>

<!-- ===== STICKY SALES BAR ===== -->
<div id="stickySalesBar" style="position:fixed;bottom:0;left:0;right:0;background:rgba(10,15,26,0.95);backdrop-filter:blur(12px);border-top:1px solid rgba(37,99,235,0.2);padding:0.75rem 1rem;z-index:9999;transform:translateY(100%);transition:transform 0.5s cubic-bezier(0.16,1,0.3,1);display:flex;align-items:center;justify-content:center;gap:1rem;flex-wrap:wrap">
  <span style="color:#e2e8f0;font-size:0.875rem">ðŸœš Get the <strong style="color:#3b82f6">Complete Toolkit</strong> â€ templates, guides & resources</span>
  <a href="https://dogeking0.gumroad.com/l/wmbpq" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.5rem 1.25rem;background:linear-gradient(135deg,#2563eb,#3b82f6);color:#fff;border-radius:8px;font-weight:600;font-size:0.813rem;text-decoration:none;transition:all 0.3s">Get It Now â†™</a>
  <button onclick="document.getElementById('stickySalesBar').style.transform='translateY(100%)'" style="background:none;border:none;color:#64748b;cursor:pointer;font-size:1.2rem;padding:0.25rem">âœ•</button>
</div>
<script>
// Show sticky bar after 5 seconds
setTimeout(function(){
  var bar = document.getElementById('stickySalesBar');
  if(bar) bar.style.transform = 'translateY(0)';
}, 5000);
// Hide on scroll to bottom
var lastScrollY = 0;
window.addEventListener('scroll', function(){
  var bar = document.getElementById('stickySalesBar');
  if(!bar) return;
  if(window.innerHeight + window.scrollY >= document.body.offsetHeight - 200){
    bar.style.transform = 'translateY(100%)';
  }
});
</script>

</body>
