  <style>
/* ===== CRITICAL CSS - Inlined for Core Web Vitals ===== */
html { scroll-behavior: smooth; }
body { font-family: 'Inter', system-ui, -apple-system, sans-serif; color: #f1f5f9; line-height: 1.6; margin: 0; padding: 0; }
*,*::before,*::after { margin: 0; padding: 0; box-sizing: border-box; }

/* Hero section */
.hero { min-height: 70vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 6rem 1.5rem 4rem; position: relative; overflow: hidden; }
.hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.1; margin-bottom: 1rem; }
.hero p { font-size: clamp(1rem, 2vw, 1.25rem); max-width: 560px; margin: 0 auto 2rem; }

/* Navigation */
nav { background: rgba(12,10,29,0.8); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(2563eb,0.15); position: fixed; top: 0; left: 0; right: 0; z-index: 1000; padding: 0 1.5rem; }
.nav-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 60px; }
.nav-links { display: flex; gap: 1.5rem; list-style: none; }
.nav-links a { color: #94a3b8; text-decoration: none; font-size: 0.875rem; }

/* Container */
.container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

/* Stats */
.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 800px; margin: 0 auto; }

@media (max-width: 768px) { .nav-links { display: none; } .stats-grid { grid-template-columns: 1fr; } }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --navy:#1e3a5f;--navy-dark:#15294a;--navy-light:#25508a;
      --gold:#d4a017;--gold-light:#e2b84d;
      --accent:#e94560;--accent-light:#ff6b81;
      --bg:#0f0f23;--surface:#1a1a3e;--surface2:#2a2a5e;
      --text:#f1f5f9;--muted:#94a3b8;--border:rgba(30,58,95,.2);
      --glass-bg:rgba(15,15,35,0.7);--glass-blur:blur(20px);
      --glass-border:1px solid rgba(30,58,95,.15);
      --glass-shadow:0 8px 32px rgba(0,0,0,.35);
      --container:1280px;--pad:1rem;--radius:14px;--nav-h:64px
    }
    html{scroll-behavior:smooth}
    body{font-family:'Inter',system-ui,-apple-system,sans-serif;background:var(--bg);color:var(--text);line-height:1.6;min-height:100vh;overflow-x:hidden}
    a{color:var(--gold);text-decoration:none;transition:color .3s}
    a:hover{color:var(--gold-light)}
    .container{max-width:var(--container);margin:0 auto;padding:0 var(--pad)}
    .glass{background:var(--glass-bg);backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);border:var(--glass-border);box-shadow:var(--glass-shadow)}

    /* NAVIGATION */
    nav{position:fixed;top:0;left:0;right:0;height:var(--nav-h);z-index:1000;background:rgba(15,15,35,.88);backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);border-bottom:1px solid rgba(30,58,95,.15);animation:navIn .5s ease-out}
    @keyframes navIn{from{transform:translateY(-100%);opacity:0}to{transform:translateY(0);opacity:1}}
    .nav-inner{max-width:var(--container);margin:0 auto;padding:0 var(--pad);height:100%;display:flex;align-items:center;justify-content:space-between}
    .nav-brand{display:flex;align-items:center;gap:.5rem;color:var(--text);font-size:1.2rem;font-weight:700;text-decoration:none}
    .nav-brand .gold{color:var(--gold)}
    .nav-links{display:flex;align-items:center;gap:1.75rem;list-style:none}
    .nav-links a{color:#94a3b8;font-size:.875rem;font-weight:500;transition:color .3s;position:relative}
    .nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:linear-gradient(90deg,var(--gold),var(--gold-light));transition:width .3s}
    .nav-links a:hover::after,.nav-links a.active::after{width:100%}
    .nav-links a:hover,.nav-links a.active{color:var(--gold)}
    .nav-cta{padding:.5rem 1.25rem;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:#0f0f23!important;border-radius:8px;font-weight:600!important;font-size:.813rem!important}
    .nav-cta::after{display:none!important}
    .nav-cta:hover{box-shadow:0 4px 15px rgba(212,160,23,.3)!important}
    .hamburger{display:none;flex-direction:column;gap:5px;background:none;border:1px solid rgba(212,160,23,.3);border-radius:8px;padding:8px 10px;cursor:pointer}
    .hamburger span{display:block;width:20px;height:2px;background:#94a3b8;border-radius:2px;transition:all .3s}

    /* HERO */
    .hero{padding:8rem 0 4rem;background:linear-gradient(135deg,#0f0f23 0%,#1a1a3e 40%,rgba(30,58,95,.2) 100%);text-align:center;position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(circle at 30% 50%,rgba(212,160,23,.04) 0%,transparent 50%);animation:heroGlow 10s ease-in-out infinite;pointer-events:none}
    @keyframes heroGlow{0%,100%{opacity:.4;transform:scale(1)}50%{opacity:1;transform:scale(1.08)}}
    .hero-content{position:relative;z-index:1;max-width:800px;margin:0 auto}
    .hero-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.35rem 1rem;border-radius:999px;font-size:.75rem;font-weight:600;background:rgba(30,58,95,.4);border:1px solid rgba(212,160,23,.2);color:var(--gold);margin-bottom:1.5rem}
    .hero h1{font-size:clamp(2rem,4.5vw,3.2rem);font-weight:800;line-height:1.15;margin-bottom:1rem}
    .hero h1 .gradient{background:linear-gradient(135deg,var(--gold),var(--gold-light),var(--accent),var(--accent-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .hero h1 .navy-highlight{color:var(--navy-light)}
    .hero p{font-size:1.125rem;color:var(--muted);max-width:640px;margin:0 auto 2rem}
    .hero-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    .btn-primary{display:inline-flex;align-items:center;gap:.5rem;padding:.85rem 2rem;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:#0f0f23;border:none;border-radius:12px;font-weight:700;font-size:.938rem;cursor:pointer;transition:all .3s;text-decoration:none}
    .btn-primary:hover{transform:translateY(-3px);box-shadow:0 8px 30px rgba(212,160,23,.35)}
    .btn-secondary{display:inline-flex;align-items:center;gap:.5rem;padding:.85rem 2rem;background:rgba(30,58,95,.3);backdrop-filter:blur(8px);border:1px solid rgba(212,160,23,.25);color:#cbd5e1;border-radius:12px;font-weight:600;font-size:.938rem;cursor:pointer;transition:all .3s;text-decoration:none}
    .btn-secondary:hover{transform:translateY(-3px);border-color:var(--gold);color:var(--gold);box-shadow:0 8px 25px rgba(212,160,23,.15)}

    /* STATS BAR */
    .stats-bar{padding:2.5rem 0;border-top:1px solid rgba(30,58,95,.15);border-bottom:1px solid rgba(30,58,95,.15)}
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}
    .stat-item{text-align:center;padding:1rem}
    .stat-num{font-family:'JetBrains Mono',monospace;font-size:1.75rem;font-weight:500;color:var(--gold)}
    .stat-lbl{font-size:.8rem;color:var(--muted);margin-top:.25rem}

    /* FEATURES */
    .features{padding:4rem 0}
    .features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
    .feature-card{background:rgba(26,26,62,.55);backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);border:var(--glass-border);border-radius:var(--radius);padding:2rem;transition:all .3s;text-align:center}
    .feature-card:hover{transform:translateY(-4px);border-color:rgba(212,160,23,.2);box-shadow:0 10px 35px rgba(212,160,23,.08)}
    .feature-icon{font-size:2.2rem;margin-bottom:.75rem}
    .feature-card h3{font-size:1.05rem;font-weight:600;margin-bottom:.5rem}
    .feature-card p{color:var(--muted);font-size:.85rem;line-height:1.6}

    /* ARTICLES */
    .articles-wrap{padding:4rem 0}
    .section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem}
    .section-head h2{font-size:1.5rem;font-weight:700}
    .section-head .count{color:var(--muted);font-size:.875rem;font-family:'JetBrains Mono',monospace}
    .cats-scroll{display:flex;gap:.5rem;overflow-x:auto;padding:.5rem 0;margin-bottom:2rem;-ms-overflow-style:none;scrollbar-width:none}
    .cats-scroll::-webkit-scrollbar{display:none}
    .cat-chip{flex-shrink:0;padding:.5rem 1.125rem;border-radius:999px;font-size:.8rem;font-weight:500;background:rgba(30,58,95,.2);border:1px solid rgba(30,58,95,.2);color:var(--muted);cursor:pointer;transition:all .3s;white-space:nowrap;font-family:'Inter',sans-serif}
    .cat-chip:hover{border-color:var(--gold);color:var(--gold)}
    .cat-chip.active{background:rgba(212,160,23,.15);border-color:var(--gold);color:var(--gold)}
    .articles-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1.25rem}
    .article-card{background:rgba(26,26,62,.55);backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);border:var(--glass-border);border-radius:var(--radius);padding:1.5rem;transition:all .3s;cursor:pointer;position:relative;overflow:hidden;opacity:0;transform:translateY(20px)}
    .article-card.visible{opacity:1;transform:translateY(0)}
    .article-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--navy),var(--gold));opacity:0;transition:opacity .3s}
    .article-card:hover{transform:translateY(-5px);border-color:rgba(212,160,23,.25);box-shadow:0 12px 40px rgba(212,160,23,.1)}
    .article-card:hover::before{opacity:1}
    .article-card .cat-badge{display:inline-block;padding:.25rem .625rem;border-radius:999px;font-size:.675rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.75rem}
    .article-card .meta{display:flex;align-items:center;gap:.75rem;font-size:.75rem;color:#64748b;margin-bottom:.625rem}
    .article-card .meta .dot{width:3px;height:3px;border-radius:50%;background:#475569}
    .article-card h3{font-size:1.05rem;font-weight:600;line-height:1.4;margin-bottom:.5rem;color:var(--text);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .article-card .excerpt{font-size:.85rem;color:var(--muted);line-height:1.6;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:.75rem}
    .article-card .tags{display:flex;flex-wrap:wrap;gap:.3rem}
    .article-card .tag{font-size:.675rem;padding:.15rem .45rem;border-radius:4px;background:rgba(30,58,95,.2);color:#93c5fd}
    .cat-resume{background:rgba(233,69,96,.15);color:#fda4af}
    .cat-linkedin{background:rgba(30,58,95,.3);color:#93c5fd}
    .cat-interview{background:rgba(212,160,23,.15);color:#fcd34d}
    .cat-career{background:rgba(16,185,129,.15);color:#6ee7b7}
    .cat-ats{background:rgba(168,85,247,.15);color:#d8b4fe}
    .cat-general{background:rgba(148,163,184,.15);color:#cbd5e1}

    /* SERVICES SECTION */
    .services-section{padding:4rem 0;background:linear-gradient(180deg,#0f0f23 0%,rgba(30,58,95,.08) 100%);border-top:1px solid rgba(30,58,95,.15);border-bottom:1px solid rgba(30,58,95,.15)}
    .services-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem}
    .service-card{background:rgba(26,26,62,.65);backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);border:var(--glass-border);border-radius:var(--radius);padding:1.75rem;transition:all .3s;position:relative;overflow:hidden}
    .service-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--navy),var(--gold));opacity:0;transition:opacity .3s}
    .service-card:hover{transform:translateY(-4px);border-color:rgba(212,160,23,.2);box-shadow:0 10px 35px rgba(212,160,23,.08)}
    .service-card:hover::before{opacity:1}
    .service-badge{display:inline-block;padding:.2rem .6rem;border-radius:999px;font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.75rem;background:rgba(30,58,95,.3);color:#93c5fd}
    .service-card h3{font-size:1.1rem;font-weight:600;margin-bottom:.35rem}
    .service-price{font-size:1.4rem;font-weight:700;color:var(--gold);margin:.5rem 0}
    .service-desc{color:var(--muted);font-size:.85rem;margin-bottom:.75rem;line-height:1.5}
    .service-features{list-style:none;margin-bottom:1rem}
    .service-features li{padding:.3rem 0 .3rem 1.4rem;position:relative;font-size:.8rem;color:#cbd5e1}
    .service-features li::before{content:'\2713';position:absolute;left:0;color:var(--gold);font-weight:700}
    .service-btn{display:inline-flex;align-items:center;gap:.4rem;padding:.65rem 1.35rem;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:#0f0f23;border:none;border-radius:10px;font-weight:600;font-size:.813rem;cursor:pointer;text-decoration:none;transition:all .3s}
    .service-btn:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(212,160,23,.3)}

    /* NEWSLETTER */
    .newsletter{padding:4rem 0;text-align:center;background:linear-gradient(135deg,#0f0f23,#1a1a3e)}
    .newsletter-box{max-width:520px;margin:0 auto}
    .newsletter-box h2{font-size:1.4rem;font-weight:700;margin-bottom:.75rem}
    .newsletter-box p{color:var(--muted);font-size:.938rem;margin-bottom:1.5rem}
    .newsletter-form{display:flex;gap:.75rem;max-width:480px;margin:0 auto;flex-direction:row;align-items:flex-end}
    .newsletter-form input{flex:1;padding:.75rem 1rem;background:rgba(30,58,95,.2);border:1px solid rgba(212,160,23,.2);border-radius:10px;color:var(--text);font-size:.938rem;outline:none;transition:border-color .3s;font-family:'Inter',sans-serif}
    .newsletter-form input:focus{border-color:var(--gold)}
    .newsletter-form input::placeholder{color:#64748b}
    .newsletter-form button{padding:.75rem 1.5rem;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:#0f0f23;border:none;border-radius:10px;font-weight:600;font-size:.875rem;cursor:pointer;transition:all .3s;white-space:nowrap;font-family:'Inter',sans-serif}
    .newsletter-form button:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(212,160,23,.3)}
    .newsletter-input-group{display:flex;flex-direction:column;gap:.5rem;flex:1}
    .newsletter-name-input{padding:.75rem 1rem;background:rgba(15,23,42,.6);border:1px solid rgba(37,99,235,.25);border-radius:10px;color:var(--text);font-size:.938rem;font-family:'Inter',sans-serif;outline:none;transition:border-color .3s;width:100%}
    .newsletter-name-input:focus{border-color:var(--gold)}
    .newsletter-name-input::placeholder{color:#64748b}
    .newsletter-success{text-align:center;padding:2rem;animation:fadeInUp .5s ease-out}
    .newsletter-success .success-icon{width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,#059669,#10b981);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.5rem;color:#fff;box-shadow:0 0 30px rgba(5,150,105,.3)}
    .newsletter-success h3{font-size:1.2rem;margin-bottom:.5rem}
    .newsletter-success p{color:#94a3b8;font-size:.875rem}
    @keyframes fadeInUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    .newsletter-proof{font-size:.75rem;color:#475569;margin-top:.75rem}
    #newsletterError{color:#ef4444;font-size:0.813rem;margin-top:0.5rem;text-align:center}

    /* FOOTER */
    footer{padding:3rem 0 1.5rem;border-top:1px solid rgba(30,58,95,.15)}
    .footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:2rem;margin-bottom:2rem}
    .footer-brand h3{font-size:1.1rem;font-weight:700;margin-bottom:.75rem}
    .footer-brand h3 .gold{color:var(--gold)}
    .footer-brand p{font-size:.813rem;color:#64748b;line-height:1.6}
    .footer-col h4{font-size:.8rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:1rem}
    .footer-col a{display:block;font-size:.875rem;color:#64748b;margin-bottom:.5rem;transition:color .3s}
    .footer-col a:hover{color:var(--gold)}
    .footer-bottom{border-top:1px solid rgba(30,58,95,.15);padding-top:1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem}
    .footer-bottom p{font-size:.75rem;color:#475569}

    /* RESPONSIVE */
    @media(max-width:768px){
      .nav-links{display:none}
      .hamburger{display:flex}
      .nav-links.mobile-open{display:flex;flex-direction:column;position:fixed;top:var(--nav-h);left:0;right:0;background:rgba(15,15,35,.98);backdrop-filter:var(--glass-blur);padding:1.5rem;gap:1rem;border-bottom:1px solid rgba(30,58,95,.15);z-index:999}
      .stats-grid{grid-template-columns:repeat(2,1fr)}
      .features-grid{grid-template-columns:1fr}
      .articles-grid{grid-template-columns:1fr}
      .services-grid{grid-template-columns:1fr}
      .newsletter-form{flex-direction:column}
      .newsletter-input-group{width:100%}
      .newsletter-form button{width:100%}
      .footer-grid{grid-template-columns:1fr 1fr}
      .footer-grid>:first-child{grid-column:1/-1}
      .hero{padding:6rem 0 3rem}
      .footer-bottom{flex-direction:column;text-align:center}
    }
    @media(max-width:480px){
      .stat-num{font-size:1.4rem}
      .hero h1{font-size:1.75rem}
      .hero p{font-size:1rem}
    }
    @media(min-width:769px)and(max-width:1024px){
      .articles-grid{grid-template-columns:repeat(2,1fr)}
      .features-grid{grid-template-columns:repeat(2,1fr)}
      .services-grid{grid-template-columns:repeat(2,1fr)}
      .footer-grid{grid-template-columns:1fr 1fr 1fr}
    }

    /* SCROLL ANIMATIONS */
    .reveal{opacity:0;transform:translateY(30px);transition:opacity .6s ease-out,transform .6s ease-out}
    .reveal.visible{opacity:1;transform:translateY(0)}
    @media(prefers-reduced-motion:reduce){
      *,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;transition-duration:.01ms!important;scroll-behavior:auto!important}
      .article-card,.reveal{opacity:1;transform:none}
    }

    /* SCROLLBAR */
    ::-webkit-scrollbar{width:8px}
    ::-webkit-scrollbar-track{background:#0f0f23}
    ::-webkit-scrollbar-thumb{background:var(--surface);border-radius:4px}
    ::-webkit-scrollbar-thumb:hover{background:var(--surface2)}

    .share-btn:hover { transform: translateY(-2px); border-color: #3b82f6; }

    /* ===== CATEGORY FILTER & SEARCH ===== */
    .filter-btn {
      padding: 0.5rem 1rem;
      background: rgba(15,23,42,0.5);
      border: 1px solid rgba(37,99,235,0.2);
      border-radius: 20px;
      color: #94a3b8;
      font-size: 0.813rem;
      font-family: 'Inter', sans-serif;
      cursor: pointer;
      transition: all 0.3s;
    }
    .filter-btn:hover { border-color: #3b82f6; color: #3b82f6; }
    .filter-btn.active { background: rgba(37,99,235,0.15); border-color: #3b82f6; color: #3b82f6; }
    .search-bar input:focus { border-color: #3b82f6; }
  </style>

